<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>enrollment-history</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="details-page">
        <h1 class="details-title">Enrollment History</h1>

        <% if (enrollments.length === 0) { %>
            <p class="details-description">No enrollments yet.</p>
        <% } else { %>
            <div class="details-section">
                <% enrollments.forEach(function(enrollment) { %>
                    <a class="enrollment-card" href="/enrollments/<%= enrollment._id %>">
                        <div class="enrollment-card-info">
                            <span class="enrollment-card-title">
                                <%= enrollment.activityId ? enrollment.activityId.title : 'Activity no longer available' %>
                            </span>
                            <span class="enrollment-card-child">Child: <%= enrollment.childName %></span>
                        </div>
                        <span class="enrollment-status enrollment-status-<%= enrollment.status.toLowerCase() %>"><%= enrollment.status %></span>
                    </a>
                <% }) %>
            </div>
        <% } %>
    </div>
</body>
</html>
