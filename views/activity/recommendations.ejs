<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recommended for You</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="activities-page">
        <h1 class="page-title">Recommended for You</h1>

        <form class="auth-form recommend-form" action="/activities/recommendations" method="get">
            <label for="age">Child's Age</label>
            <input name="age" id="age" type="number" value="<%= age || '' %>">

            <label for="interests">Interests (comma separated)</label>
            <input name="interests" id="interests" type="text" value="<%= interests || '' %>">

            <button class="btn btn-primary" type="submit">Get Recommendations</button>
        </form>

        <% if (searched) { %>
            <h2 class="section-title">Results</h2>
            <% if (recommendedActivities.length === 0) { %>
                <p class="details-description">Sorry No matching activities found. Try a different age or interests.</p>
            <% } else { %>
                <div class="activities-grid">
                    <% for (let oneActivity of recommendedActivities) { %>
                        <a href="/activities/<%= oneActivity._id %>" class="activity-card">
                            <% if (oneActivity.imageUrl) { %>
                                <img class="activity-card-img" src="<%= oneActivity.imageUrl %>" alt="<%= oneActivity.title %>">
                            <% } else { %>
                                <div class="activity-card-img activity-card-img-placeholder">No Image</div>
                            <% } %>
                            <div class="activity-card-body">
                                <h3 class="activity-card-title"><%= oneActivity.title %></h3>
                                <span class="activity-card-category"><%= oneActivity.category %></span>
                                <p class="activity-card-age">Ages <%= oneActivity.minAge %> - <%= oneActivity.maxAge %></p>
                            </div>
                        </a>
                    <% } %>
                </div>
            <% } %>
        <% } %>
    </div>
</body>
</html>
